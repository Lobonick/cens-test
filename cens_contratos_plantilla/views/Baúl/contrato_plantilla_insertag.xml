<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="plantilla_insertag_form" model="ir.ui.view">
            <field name="name">hr.contract.plantilla_insertag.form</field>
            <field name="model">hr.contract.plantilla_insertag</field>
            <field name="arch" type="xml">
                <form string="Plantilla Insertag">
                    <header>
                        <button name="confirmar_insertag" string="Confirmar" type="object" class="btn-primary" attrs="{'invisible': [('state', 'in', ['posted', 'annul'])]}"/>
                        <span class="oe_inline oe_separating_element"> </span>
                        <button name="borrador_insertag" string="Regresar a Borrador" type="object" class="btn-primary" attrs="{'invisible': [('state', 'in', ['draft', 'borrador'])]}"/>
                        <span class="oe_inline oe_separating_element"> </span>
                        <button name="anula_insertag" string="Anular" type="object" class="btn-primary" attrs="{'invisible': [('state', 'in', ['draft', 'annul'])]}"/>
                        <field name="state" string="" widget="statusbar" class="oe_right" readonly="1"/>
                    </header>
                    <sheet>
                        <field name="cens_marcador_cabecera" class="oe_left" options="{&quot;size&quot;:[0,90]}" widget="image"/>
                        <field name="cens_img_insertag" class="oe_right" options="{&quot;size&quot;:[0,90]}" widget="image"/>
                        <separator/>
                        <div class="oe_title">
                            <h1>
                            <field class="text-break" name="name" placeholder="{etiqueta}" options="{&quot;size&quot;:[0,190]}"/>
                            </h1>
                        </div>
                        <group></group>
                        <group>
                            <group string="DATOS GENERALES">
                                <field name="company_id" widget="many2one"/>
                                <field name="cens_campo_descripcion"/>
                                <field name="cens_campo_tecnico"/>
                                <field name="cens_campo_seleccionado"/>
                            </group>
                            <group></group>
                        </group>
                        
                        <group>
                            <separator/>
                        </group>
                    </sheet>
  


                    <!--
    
                    -->
                </form>    
            </field>
        </record>

        <record id="plantilla_insertag_tree" model="ir.ui.view">
            <field name="name">hr.contract.plantilla_insertag.tree</field>
            <field name="model">hr.contract.plantilla_insertag</field>
            <field name="arch" type="xml">
                <tree string="Insertag" multi_edit="0" sample="1" edit="false" delete="true" duplicate="false" import="true" create="true" expand="1">
                    <field name="name" string="Nombre Etiqueta" readonly="1"/>
                    <field name="cens_campo_descripcion" string="Descripción Uso"/>
                    <field name="cens_campo_tecnico" string="Nombre técnico"/>
                    <field name="cens_campo_seleccionado" string="Campo Seleccionado"/>
                    <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" optional="show"/>
                </tree>
            </field>
        </record>

        <record id="view_plantilla_insertag_search" model="ir.ui.view">
            <field name="name">hr.contract.plantilla_insertag.search.pdv.view</field>
            <field name="model">hr.contract.plantilla_insertag</field>
            <field name="arch" type="xml">
                <search string="Etiquetas de Inserción">
                    <field name="name" />
                    <field name="cens_campo_tecnico"/>                 
                </search>
            </field>
        </record>

        <!--
            UBICACION EN EL MENU
        -->

        <record id="plantilla_insertag_action" model="ir.actions.act_window">
            <field name="name">Etiquetas de Inserción</field>
            <field name="res_model">hr.contract.plantilla_insertag</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_plantilla_insertag_search"/>
            <field name="domain">[]</field>
            <field name="context">{}</field>
        </record>

        <menuitem
            action="plantilla_insertag_action"
            id="menu_human_resources_configuration_insertag"
            name="Etiquetas de Inserción"
            parent="hr.menu_human_resources_configuration" sequence="171"/>

    </data>
</odoo>



