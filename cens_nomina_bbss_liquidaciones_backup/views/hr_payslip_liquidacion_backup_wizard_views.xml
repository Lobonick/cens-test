<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_liquidacion_backup_wizard_form" model="ir.ui.view">
        <field name="name">hr.payslip.liquidacion.backup.wizard.form</field>
        <field name="model">hr.payslip.liquidacion.backup.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="info" nolabel="1" readonly="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Ejecutar Respaldo Ahora" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_payslip_liquidacion_backup_wizard" model="ir.actions.act_window">
        <field name="name">Ejecutar Respaldo BBSS Ahora</field>
        <field name="res_model">hr.payslip.liquidacion.backup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_hr_payslip_liquidacion_backup_wizard"
              name="Ejecutar Respaldo BBSS Ahora"
              parent="hr_payroll.menu_hr_payroll_payslips"
              action="action_hr_payslip_liquidacion_backup_wizard"
              sequence="105"/>

</odoo>
