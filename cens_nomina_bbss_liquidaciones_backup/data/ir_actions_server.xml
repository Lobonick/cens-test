<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_actions_server_hr_payslip_liquidacion_backup_run" model="ir.actions.server">
        <field name="name">Ejecutar Respaldo BBSS Ahora</field>
        <field name="model_id" ref="model_hr_payslip_liquidacion_backup"/>
        <field name="binding_model_id" ref="model_hr_payslip_liquidacion_backup"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.action_run_backup_all()</field>
    </record>

    <record id="ir_actions_server_hr_payslip_liquidacion_backup_restore" model="ir.actions.server">
        <field name="name">Restaurar Seleccionados</field>
        <field name="model_id" ref="model_hr_payslip_liquidacion_backup"/>
        <field name="binding_model_id" ref="model_hr_payslip_liquidacion_backup"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_run_restore()</field>
    </record>

</odoo>
