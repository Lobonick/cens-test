<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_payslip_mass_send" model="mail.template">
            <field name="name">Plantilla Boleta de Pago</field>
            <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
            <field name="subject">Boleta de Pago - ${object.employee_id.name}</field>
            <field name="email_from">${object.company_id.email}</field>
            <field name="email_to">${object.employee_id.work_email}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Estimado/a ${object.employee_id.name},
                        <br/><br/>
                        Adjunto encontrará su boleta de pago correspondiente al período ${object.date_from} al ${object.date_to}.
                        <br/><br/>
                        Saludos cordiales,
                        <br/>
                        ${object.company_id.name}
                    </p>
                </div>
            </field>
            <field name="lang">${object.employee_id.lang}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>