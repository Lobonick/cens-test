                <page name="cens_page_renta_1" string="Renta 5ta.Cat." attrs="{'invisible': [['x_studio_renta_5ta','=',False]]}">
                    <group name="group_01">
                        <group name="group_01_left">
                            <separator string="Parámetros Considerados"/>
                            <field name="cens_nano_ejercicio" string="Ejercicio actual:"/>
                            <field name="cens_renta_quinta_id" 
                                 string="Configuración Renta 5ta.Cat" 
                                 domain="[('employee_id', '=', employee_id), ('cens_anio_ejercicio', '=', cens_nano_ejercicio)]"/>
                            <field name="cens_tiene_renta5ta"/>
                            <field name="cens_sueldo_minimo"/>
                            <field name="cens_uit_importe"/>
                            <separator/>
                            <field name="cens_logo_sunat" options="{&quot;size&quot;:[0,270]}" widget="image" />
                        </group>
                        <!--
                        <group name="group_01_right">
                            <separator string="Proyectado de Retenciones"/>
                            <field name="cens_reten_ene" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'ENERO'"/>
                            <field name="cens_reten_feb" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'FEBRERO'"/>
                            <field name="cens_reten_mar" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'MARZO'"/>
                            <field name="cens_reten_abr" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'ABRIL'"/>
                            <field name="cens_reten_may" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'MAYO'"/>
                            <field name="cens_reten_jun" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'JUNIO'"/>
                            <field name="cens_reten_jul" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'JULIO'"/>
                            <field name="cens_reten_ago" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'AGOSTO'"/>
                            <field name="cens_reten_set" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'SETIEMBRE'"/>
                            <field name="cens_reten_oct" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'OCTUBRE'"/>
                            <field name="cens_reten_nov" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'NOVIEMBRE'"/>
                            <field name="cens_reten_dic" readonly="1" class="text-right" decoration-danger="x_studio_mes_calculado == 'DICIEMBRE'"/>
                            <separator string="_"/>
                        </group>
                        -->
                    </group>
                    <group name="group_02">
                        <group name="group_02_left">

                        </group>
                        <group name="group_02_right">
                            
                        </group>
                    </group>

                </page>
            </notebook>
        </field>
    </record>


</odoo>





