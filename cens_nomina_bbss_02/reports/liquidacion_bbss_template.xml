<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="liquidacion_bbss_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                        <style>
                            @page {
                                size: A4 portrait;
                            }
                            
                            /* @charset "UTF-8"; */
                            
                            .page {
                                /* width: 210mm; */
                                /* min-height: 297mm; */
                                background: white;
                                font-family: Arial, sans-serif; /* Fuente que soporta UTF-8 */
                                margin: 0;
                                padding: 5mm 0 0 0; /* Padding superior mínimo */
                            }
                            
                            /* Estilo para la imagen del header */
                            .company-logo {
                                width: 150px;
                                height: 150px;
                                object-fit: contain;
                                margin: 0 auto 20px auto;
                                display: block;
                            }
                            
                            .header-company {
                                text-align: center;
                                margin-bottom: 30px;
                                padding-bottom: 20px;
                                border-bottom: 2px solid #875A7B;
                            }

                            .section-title {
                                background-color: #875A7B;
                                color: white;
                                padding: 8px;
                                font-weight: bold;
                                font-size: 14px;
                                margin: 15px 0 10px 0;
                                position: relative;
                                padding-left: 35px; /* Espacio para el icono */
                            }

                            .info-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 15px;
                            }
                            .info-table td {
                                padding: 5px 8px;
                                border: 1px solid #ddd;
                                font-size: 12px;
                            }
                            .info-table .label {
                                background-color: #f8f9fa;
                                font-weight: bold;
                                width: 20%;
                            }
                            .info-table .label1 {
                                background-color: #f8f9fa;
                                font-weight: bold;
                                width: 12%;
                            }
                            .calculation-section {
                                margin: 20px 0;
                                border: 1px solid #ddd;
                                border-radius: 5px;
                            }
                            .calc-header {
                                background-color: #128C7E;
                                color: white;
                                padding: 10px;
                                font-weight: bold;
                                font-size: 14px;
                            }
                            .calc-content {
                                padding: 15px;
                            }
                            .calc-row {
                                display: flex;
                                justify-content: space-between;
                                margin: 5px 0;
                                padding: 5px 0;
                                border-bottom: 1px solid #eee;
                            }
                            .calc-total {
                                background-color: #a8e6cf;
                                color: #2d5016;
                                font-weight: bold;
                                padding: 10px;
                                border-radius: 5px;
                                margin: 10px 0;
                            }
                            .monetary {
                                text-align: right;
                                font-family: monospace;
                            }
                            .monetary-total {
                                background-color: #a8e6cf;
                                color: #2d5016;
                                font-weight: bold;
                                text-align: right;
                            }
                            .warning-text {
                                color: red;
                                font-weight: bold;
                            }
                        </style>

                        <!-- Header con imagen de la empresa -->
                        <div class="header-company">
                            <!-- MÉTODO 1: Imagen desde campo de la empresa -->
                            <img t-if="o.company_id.logo" 
                                class="company-logo"
                                t-att-src="'data:image/png;base64,' + o.company_id.logo.decode('utf-8')"
                                alt="Logo de la empresa"/>
                            
                            <!-- MÉTODO 2: Imagen estática desde el módulo -->
                            <!-- <img class="company-logo" 
                                src="/cens_nomina_bbss_02/static/description/company_logo.png" 
                                alt="Logo CENS"/> -->
                            
                            <!-- MÉTODO 3: Imagen por defecto si no hay logo -->
                            <div t-if="not o.company_id.logo" 
                                style="width: 150px; height: 150px; border: 2px dashed #ccc; 
                                        display: flex; align-items: center; justify-content: center; 
                                        margin: 0 auto 20px auto; color: #999;">
                                Logo de la Empresa
                            </div>
                            
                            <h3><span t-esc="o.company_id.name"/></h3>
                            <p>RUC: <span t-esc="o.company_id.vat"/></p>
                        </div>

                        <!-- Encabezado del documento _____________________________________________________ -->
                        <div class="header-company">
                            <h1>LIQUIDACIÓN DE BENEFICIOS SOCIALES</h1>
                        </div>

                        <!-- Información del empleado -->
                        <div class="section-title">INFORMACIÓN DEL EMPLEADO</div>
                        <table class="info-table">
                            <tr>
                                <td class="label1">Empleado:</td>
                                <td><span t-esc="o.employee_id.name"/></td>
                                <td class="label1">DNI:</td>
                                <td><span t-esc="o.employee_id.identification_id"/></td>
                            </tr>
                            <tr>
                                <td class="label1">Cargo:</td>
                                <td><span t-esc="o.employee_id.job_id.name"/></td>
                                <td class="label1">Departamento:</td>
                                <td><span t-esc="o.employee_id.department_id.name"/></td>
                            </tr>
                            <tr>
                                <td class="label">Fecha de Ingreso:</td>
                                <td><span t-esc="o.x_studio_cese_fecha_ingreso" t-options="{'widget': 'date'}"/></td>
                                <td class="label">Fecha de Cese:</td>
                                <td><span t-esc="o.x_studio_cese_fecha" t-options="{'widget': 'date'}"/></td>
                            </tr>
                        </table>

                        <!-- Información del período -->
                        <div class="section-title">PARÁMETROS DE CÁLCULO</div>
                        <table class="info-table">
                            <tr>
                                <td class="label1">Período laboral:</td>
                                <td>
                                    <span>Desde </span>
                                    <span t-esc="o.x_cens_periodo_ini" t-options="{'widget': 'date'}"/> al 
                                    <span t-esc="o.x_cens_periodo_fin" t-options="{'widget': 'date'}"/>
                                </td>

                                <td class="label1">Remuneración Base:</td>
                                <td class="monetary">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_remu_base or 0)"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="label1">Tiempo de Servicio:</td>
                                <td>
                                    <span t-esc="o.x_cens_periodo_aa"/> años, 
                                    <span t-esc="o.x_cens_periodo_mm"/> meses, 
                                    <span t-esc="o.x_cens_periodo_dd"/> días
                                </td>

                                <td class="label1">Asignación Familiar:</td>
                                <td class="monetary">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_asig_fami or 0)"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="label">Moneda:</td>
                                <td><span t-esc="o.x_cens_moneda"/></td>

                                <td class="label1">1/6 gratificación:</td>
                                <td class="monetary">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_grat_16to or 0)"/>
                                </td>
                            </tr>
                            <tr>
                                <td> </td>
                                <td> </td>
                                
                                <td class="label">Remuneración Computable:</td>
                                <td class="monetary-total">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_remu_comp or 0)"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Liquidación CTS -->
                        <div class="calculation-section">
                            <div class="calc-header">LIQUIDACIÓN CTS</div>
                            <div class="calc-content">
                                <div class="calc-row">
                                    <span>Detalle del Período:</span>
                                    <span t-esc="o.x_cens_ccts_peri"/>
                                </div>
                                <div class="calc-row">
                                    <span>Cálculo por mes:</span>
                                    <span t-esc="o.x_cens_ccts_dmes"/>
                                </div>
                                <div class="calc-row">
                                    <span>Cálculo por día:</span>
                                    <span t-esc="o.x_cens_ccts_ddia"/>
                                </div>
                                <div class="calc-row">
                                    <span>Importe por mes:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_ccts_imes or 0)"/>
                                </div>
                                <div class="calc-row">
                                    <span>Importe por día:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_ccts_idia or 0)"/>
                                </div>
                                <div class="calc-total">
                                    <div class="calc-row">
                                        <span><strong>TOTAL CTS:</strong></span>
                                        <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_ccts_itot or 0)"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Liquidación Vacaciones -->
                        <div class="calculation-section">
                            <div class="calc-header">LIQUIDACIÓN VACACIONES</div>
                            <div class="calc-content">
                                <div class="calc-row">
                                    <span>Detalle del Período:</span>
                                    <span t-esc="o.x_cens_vaca_peri"/>
                                </div>
                                <div class="calc-row">
                                    <span>Cálculo por año:</span>
                                    <span t-esc="o.x_cens_vaca_dano"/>
                                </div>
                                <div class="calc-row">
                                    <span>Cálculo por mes:</span>
                                    <span t-esc="o.x_cens_vaca_dmes"/>
                                </div>
                                <div class="calc-row">
                                    <span>Cálculo por día:</span>
                                    <span t-esc="o.x_cens_vaca_ddia"/>
                                </div>
                                <div class="calc-row">
                                    <span>Importe por año:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_vaca_iano or 0)"/>
                                </div>
                                <div class="calc-row">
                                    <span>Importe por mes:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_vaca_imes or 0)"/>
                                </div>
                                <div class="calc-row">
                                    <span>Importe por día:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_vaca_idia or 0)"/>
                                </div>
                                <div class="calc-row warning-text">
                                    <span>Descuento AFP/ONP:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_vaca_iafp or 0)"/>
                                </div>
                                <div class="calc-total">
                                    <div class="calc-row">
                                        <span><strong>TOTAL VACACIONES:</strong></span>
                                        <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_vaca_itot or 0)"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Liquidación Gratificaciones -->
                        <div class="calculation-section">
                            <div class="calc-header">LIQUIDACIÓN GRATIFICACIONES</div>
                            <div class="calc-content">
                                <div class="calc-row">
                                    <span>Detalle del Período:</span>
                                    <span t-esc="o.x_cens_grat_peri"/>
                                </div>
                                <div class="calc-row">
                                    <span>Cálculo por mes:</span>
                                    <span t-esc="o.x_cens_grat_dmes"/>
                                </div>
                                <div class="calc-row">
                                    <span>Bonificación:</span>
                                    <span t-esc="o.x_cens_grat_dbon"/>
                                </div>
                                <div class="calc-row">
                                    <span>Importe por mes:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_grat_imes or 0)"/>
                                </div>
                                <div class="calc-row">
                                    <span>Importe bonificación:</span>
                                    <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_grat_ibon or 0)"/>
                                </div>
                                <div class="calc-total">
                                    <div class="calc-row">
                                        <span><strong>TOTAL GRATIFICACIONES:</strong></span>
                                        <span class="monetary" t-esc="'{:,.2f}'.format(o.x_cens_grat_itot or 0)"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Resumen final -->
                        <div class="section-title">RESUMEN LIQUIDACIÓN DE BB.SS.</div>
                        <table class="info-table">
                            <tr>
                                <td class="label">CTS Trunco:</td>
                                <td class="monetary">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_ccts_itot or 0)"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="label">Vacaciones Truncas (*):</td>
                                <td class="monetary">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_vaca_itot or 0)"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="label">Gratificaciones Truncas:</td>
                                <td class="monetary">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_grat_itot or 0)"/>
                                </td>
                            </tr>
                            <tr style="background-color: #a8e6cf; font-weight: bold; font-size: 16px;">
                                <td class="label">TOTAL A PAGAR:</td>
                                <td class="monetary">
                                    <span t-esc="'{:,.2f}'.format(o.x_cens_liqu_tota or 0)"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Información de aportes -->
                        <div class="section-title">INFORMACIÓN DE APORTES</div>
                        <table class="info-table">
                            <tr>
                                <td class="label">Compañía AFP/ONP:</td>
                                <td><span t-esc="o.x_studio_compania_afp"/></td>
                                <td class="label">Aporte Obligatorio:</td>
                                <td><span t-esc="o.x_cens_afp_oblig"/></td>
                            </tr>
                            <tr>
                                <td class="label">Prima Seguro:</td>
                                <td><span t-esc="o.x_cens_afp_prima"/></td>
                                <td class="label">Tipo Comisión:</td>
                                <td><span t-esc="o.x_studio_en_tipo_comision"/></td>
                            </tr>
                            <tr t-if="o.x_studio_en_tipo_comision == 'MIX'">
                                <td class="label">Comisión Mixta:</td>
                                <td><span t-esc="o.x_cens_afp_mixta"/></td>
                                <td class="label"></td>
                                <td></td>
                            </tr>
                            <tr t-if="o.x_studio_en_tipo_comision == 'FLU'">
                                <td class="label">Comisión Flujo:</td>
                                <td><span t-esc="o.x_cens_afp_flujo"/></td>
                                <td class="label"></td>
                                <td></td>
                            </tr>
                        </table>

                        <!-- Observaciones -->
                        <div class="section-title">OBSERVACIONES</div>
                        <div style="padding: 10px; border: 1px solid #ddd; min-height: 100px;">
                            <p><span t-esc="o.note"/></p>
                            <p style="font-size: 10px; color: #666;">
                                * Las vacaciones truncas incluyen el cálculo y descuento del importe ONP/AFP.
                            </p>
                        </div>

                        <!-- Pie de página con firmas -->
                        <div style="margin-top: 50px;">
                            <table style="width: 100%;">
                                <tr>
                                    <td style="text-align: center; width: 50%; padding: 20px;">
                                        <div style="border-top: 1px solid #000; margin-top: 60px; padding-top: 5px;">
                                            <strong>EMPLEADO</strong><br/>
                                            <span t-esc="o.employee_id.name"/>
                                        </div>
                                    </td>
                                    <td style="text-align: center; width: 50%; padding: 20px;">
                                        <div style="border-top: 1px solid #000; margin-top: 60px; padding-top: 5px;">
                                            <strong>EMPLEADOR</strong><br/>
                                            <span t-esc="o.company_id.name"/>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Fecha del documento -->
                        <div style="text-align: center; margin-top: 30px; font-size: 12px;">
                            Fecha de impresión: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>
                </div>
            </t>
        </t>
    </template>
</odoo>