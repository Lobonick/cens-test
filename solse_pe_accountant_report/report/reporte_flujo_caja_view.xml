<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<template id="template_reporte_flujo_caja">
		<t t-call="web.html_container">
			<t t-if="not company">
				<!-- Multicompany -->
				<t t-if="res_company">
					<t t-set="company" t-value="res_company"/>
				</t>
				<t t-else="else">
					<t t-set="company" t-value="res_company"/>
				</t>
			</t>
			
			<!-- Header -->
			<div class="header o_company_#{company.id}_layout factura" t-att-style="report_header_style">
				<div class="row">
					<div class="col-5 col-xs-4 mt32">
						<div style="text-align:center;">
							<img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height: 90px; height: 90px; max-width: 250px; display:block; margin-left: auto; margin-right: auto; top: 30%;" alt="Logo"/>
						</div>
					</div>
					<div class="col-2 text-right" >
												
					</div>
					<div class="col-5 empresa" name="company_address">
						<strong><t t-esc="company.name"/></strong>
						<br/>
						<t t-esc="company.street"/>
						-
						<t t-esc="company.partner_id.l10n_pe_district.name"/>-
						<t t-esc="company.state_id.name"/>-
						<t t-esc="company.city"/>
						
						<span t-if="company.phone">
							Telf.:<t t-esc="company.phone"/>
						</span>
					</div>
					
				</div>
			</div>
			<br/>

			<div class="article o_report_layout_clean" data-oe-model="product.product" t-att-data-oe-id="o and o.id">
				<div class="page">
					<div class="text-center" style="width: 100%;">
						<h4><t t-esc="titulo" /></h4>
						<br/>
						<h4><t t-esc="nombre_mes" /></h4>
						<!--<br/>
						<h4><t t-esc="nombre_agente" /></h4>-->
					</div>
					<br/>

					<div class="row" style="width: 100%;">
						<div style="width: 48%;">
							<table style="width: 100%;border: 0px;">
								<tr>
									<td>
										Total Servicios
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(total_servicios)" />
									</td>
								</tr>
								<tr>
									<td>
										Total Productos
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(total_productos)" />
									</td>
								</tr>
								<tr>
									<td>
										Otros Ingresos
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(otros_ingresos)" />
									</td>
								</tr>
								<tr>
									<td>
										<strong>Total Ingresos</strong>
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(total_ingresos)" />
									</td>
								</tr>
								<tr>
									<td>
										Personal
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(personal)" />
									</td>
								</tr>
								<tr>
									<td>
										Proveedores
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(proveedores)" />
									</td>
								</tr>
								<tr>
									<td>
										Gastos Fijos
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(gastos_fijos)" />
									</td>
								</tr>
								<tr>
									<td>
										Otros Gastos
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(gastos_otros)" />
									</td>
								</tr>
								<tr>
									<td>
										Comisiones x Tarjeta
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(comision_x_tarjeta)" />
									</td>
								</tr>
								<tr>
									<td>
										<strong>Total Gastos</strong>
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(total_gastos)" />
									</td>
								</tr>
								<tr>
									<td>
										Utilidad Bruta
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(utilidad_bruta)" />
									</td>
								</tr>
								<tr>
									<td>
										Cuentas por Cobrar
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(cuentas_x_cobrar)" />
									</td>
								</tr>
								<tr>
									<td>
										Inversión
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(inversion)" />
									</td>
								</tr>
								<tr>
									<td>
										Canjes y Regalos
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(canjes_y_regalos)" />
									</td>
								</tr>
								<tr>
									<td>
										Utilidad Neta
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(utilidad_neta)" />
									</td>
								</tr>
							</table>
						</div>
						<div style="width: 4%;">
						</div>
						<div style="width: 48%;">
							<table style="width: 100%;">
								<t t-foreach="metodos_pago" t-as="linea">
									<tr>
										<td>
											<t t-esc="linea['name']" />
										</td>
										<td>
											
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(linea['amount'])" />
										</td>
									</tr>
								</t>
								<tr>
									<td>
										<strong>Total Ingresos:</strong>
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(total_ingresos_mp)" />
									</td>
								</tr>
								<tr>
									<td>
										Comisiones
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(comisiones)" />
									</td>
								</tr>
								<tr>
									<td>
										<strong>Total Deposito</strong>
									</td>
									<td>
										
									</td>
									<td style="text-align: right;">
										<t t-esc="'%.2f'%(total_deposito)" />
									</td>
								</tr>
							</table>
							<div>
								<strong>COSTO DE SERVICIO</strong>
								<table style="width: 100%;">
									<tr>
										<td>
											
										</td>
										<td style="text-align: right;">
											
										</td>
										<td style="text-align: center;">
											%
										</td>
									</tr>
									<tr>
										<td>
											Costo en Prod.
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(costo_en_produccion)" />
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(costo_en_produccion)" />
										</td>
									</tr>
									<tr>
										<td>
											Costos fijos
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(costo_en_produccion)" />
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(costos_fijos)" />
										</td>
									</tr>

									<tr>
										<td>
											Otros Gastos
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(costo_en_produccion)" />
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(otros_gastos)" />
										</td>
									</tr>
									<tr>
										<td>
											Mano de Obra
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(costo_en_produccion)" />
										</td>
										<td style="text-align: right;">
											<t t-esc="'%.2f'%(mano_obra)" />
										</td>
									</tr>

									<tr>
										<td>
											<strong>Costo Total</strong>
										</td>
										<td style="text-align: right;">
											<strong><t t-esc="'%.2f'%(costo_en_produccion)" /></strong>
										</td>
										<td style="text-align: right;">
											<strong><t t-esc="'%.2f'%(costo_total)" /></strong>
										</td>
									</tr>
								</table>
							</div>
						</div>
					</div>
				</div>

			</div>

			<div class="footer" >
				<br/>
				<div class="text-center" style="border-top: 1px solid black;">
					<ul class="list-inline mb4">
						<li t-if="company.phone">Telefono: 
							<span t-field="company.phone"/></li>
						<li t-if="company.email">Email: 
							<span t-field="company.email"/></li>
						<li t-if="company.website">Web: <span t-field="company.website"/></li>

						<!--<li t-if="company.website">
							Representación impresa de factura electrónica, consulta en <span t-field="company.website"/></li>-->
					</ul>
					<div name="financial_infos">
						<span t-field="company.report_footer"/>
					</div>
					<div class="text-muted">
						<span class="page"/>
						de  
						<span class="topage"/></div>
				</div>
				
				<br/>
			</div>
		</t>
	</template>

	<report
		id="pdf_reporte_flujo_caja"
		model="product.product"
		string="Reporte Flujo de Caja"
		report_type="qweb-pdf"
		name="solse_salon_belleza.template_reporte_flujo_caja"
		file="solse_salon_belleza.template_reporte_flujo_caja"
	/>

	
	<record id="solse_salon_belleza.paperformat_reporte_flujo_caja" model="report.paperformat">
		<field name="name">Formato Papel (Reporte flujo_caja)</field>
		<field name="default" eval="True" />
		<field name="format">custom</field>
		<field name="page_height">297</field>
		<field name="page_width">210</field>
		<field name="orientation">Portrait</field>
		<field name="margin_top">25</field> <!-- la diferencia (margin_top - header_spacing) es el espacio que queda en la parte superior de la hoja-->
		<field name="header_spacing">20</field>
		<field name="margin_bottom">30</field>
		<field name="margin_left">7</field>
		<field name="margin_right">7</field>
		<field name="header_line" eval="False" /><!-- mostrar una linea en cabecera-->
		<field name="dpi">90</field>
	</record>


	<record id="solse_salon_belleza.pdf_reporte_flujo_caja" model="ir.actions.report">
		<field name="paperformat_id" ref="solse_salon_belleza.paperformat_reporte_flujo_caja"/>
	</record>

</odoo>